# This file is generated by internal/envoy_modules/generate-dockerfile.sh when the 'generate-all' make target is run.
# DO NOT EDIT BY HAND! Edit internal/envoy_modules/Dockerfile.tmpl instead.
ARG CARGO_ZBUILD_IMAGE=ghcr.io/rust-cross/cargo-zigbuild:0.19.8
# Stage 1: pull in all rust build dependency and cache it in docker build layer cache
FROM --platform=$TARGETPLATFORM ${CARGO_ZBUILD_IMAGE} AS rust_build_deps
WORKDIR /build
RUN sed -i 's|http://archive.ubuntu.com|http://azure.archive.ubuntu.com|g; s|http://security.ubuntu.com|http://azure.archive.ubuntu.com|g' /etc/apt/sources.list 2>/dev/null || true \
    && sed -i 's|http://archive.ubuntu.com|http://azure.archive.ubuntu.com|g; s|http://security.ubuntu.com|http://azure.archive.ubuntu.com|g' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null || true \
    && apt-get -o Acquire::Retries=5 update \
    && apt-get -o Acquire::Retries=5 install --no-install-recommends -y clang
ARG ENVOY_MODULES_DIR=.
# Copy rust-toolchain.toml first so rustup auto-installs the pinned toolchain
# (single source of truth for Rust version; see tools/build-tools/Dockerfile and
# .github/workflows/lint.yaml which also read this file).
COPY ${ENVOY_MODULES_DIR}/rust-toolchain.toml ./
COPY ${ENVOY_MODULES_DIR}/Cargo.toml ${ENVOY_MODULES_DIR}/Cargo.lock ./
# Workspace crate members are auto-discovered from Cargo.toml.
# To add a crate, add it to the workspace members list in Cargo.toml.
# The following section is generated by internal/envoy_modules/generate-dockerfile.sh when the make
# target is run. Do not edit by hand.
RUN mkdir -p module-init/src \
              filters/rustformation/src \
              filters/http-acl/src \
              lib/transformation/src \
              lib/envoy-helpers/src \
              lib/acl/src \
    && echo "pub fn dummy() {}" > module-init/src/lib.rs \
    && echo "pub fn dummy() {}" > filters/rustformation/src/lib.rs \
    && echo "pub fn dummy() {}" > filters/http-acl/src/lib.rs \
    && echo "pub fn dummy() {}" > lib/transformation/src/lib.rs \
    && echo "pub fn dummy() {}" > lib/envoy-helpers/src/lib.rs \
    && echo "pub fn dummy() {}" > lib/acl/src/lib.rs
COPY ${ENVOY_MODULES_DIR}/module-init/Cargo.toml ./module-init
COPY ${ENVOY_MODULES_DIR}/filters/rustformation/Cargo.toml ./filters/rustformation
COPY ${ENVOY_MODULES_DIR}/filters/http-acl/Cargo.toml ./filters/http-acl
COPY ${ENVOY_MODULES_DIR}/lib/transformation/Cargo.toml ./lib/transformation
COPY ${ENVOY_MODULES_DIR}/lib/envoy-helpers/Cargo.toml ./lib/envoy-helpers
COPY ${ENVOY_MODULES_DIR}/lib/acl/Cargo.toml ./lib/acl
ARG RUST_BUILD_ARCH=x86_64 # options are x86_64 or aarch64
# Install the cross-compilation target so cargo zigbuild can link for non-native arches.
RUN rustup target add ${RUST_BUILD_ARCH}-unknown-linux-gnu
# Because we built the dummy lib in this Stage to cache all the dependencies in docker build layer cache,
# the dummy libs are also cached. In Stage 2 when we COPY, it preserves the timestamps of the
# source code, so it never re-compiles the real lib.
# The following section is generated by internal/envoy_modules/generate-dockerfile.sh when the make
# target is run. Do not edit by hand.
RUN cargo fetch \
    && cargo zigbuild --target ${RUST_BUILD_ARCH}-unknown-linux-gnu \
    && find /build/target \( -name librust_module.so \
        -o -name 'librustformation_filter-*.rlib' \
        -o -name 'libhttp_acl_filter-*.rlib' \
        -o -name 'libtransformation-*.rlib' \
        -o -name 'libenvoy_helpers-*.rlib' \
        -o -name 'libacl-*.rlib' \
    \) -type f -delete

# Stage 2: build envoy dynamic module
FROM --platform=$TARGETPLATFORM ${CARGO_ZBUILD_IMAGE} AS rust_builder
WORKDIR /build
RUN sed -i 's|http://archive.ubuntu.com|http://azure.archive.ubuntu.com|g; s|http://security.ubuntu.com|http://azure.archive.ubuntu.com|g' /etc/apt/sources.list 2>/dev/null || true \
    && sed -i 's|http://archive.ubuntu.com|http://azure.archive.ubuntu.com|g; s|http://security.ubuntu.com|http://azure.archive.ubuntu.com|g' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null || true \
    && apt-get -o Acquire::Retries=5 update \
    && apt-get -o Acquire::Retries=5 install --no-install-recommends -y clang

# Copy cached cargo, rustup toolchain, and build target from rust_build_deps
COPY --from=rust_build_deps /usr/local/cargo /usr/local/cargo
COPY --from=rust_build_deps /usr/local/rustup /usr/local/rustup
COPY --from=rust_build_deps /build/target /build/target

# Copy the source code and build the module.
ARG ENVOY_MODULES_DIR=.
COPY ${ENVOY_MODULES_DIR} .
ARG RUST_BUILD_ARCH=x86_64 # set this to "aarch64" for local arm build
RUN cargo zigbuild --target ${RUST_BUILD_ARCH}-unknown-linux-gnu

RUN cp /build/target/${RUST_BUILD_ARCH}-unknown-linux-gnu/debug/librust_module.so /build/librust_module.so

# Stage 3: export stage — target this with --target=export --output type=local,dest=<dir>
# to extract librust_module.so to the host without loading a full image.
FROM scratch AS export
COPY --from=rust_builder /build/librust_module.so /librust_module.so
